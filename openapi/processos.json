      }
    },
    "/processos/numero/{numero}": {
      "get": {
        "operationId": "getProcessoByNumero",
        "summary": "Busca processo por numero",
        "description": "Retorna detalhes completos de um processo judicial pelo numero (com ou sem formatacao).",
        "tags": ["Processos"],
        "parameters": [
          {
            "name": "numero",
            "in": "path",
            "required": true,
            "description": "Numero do processo (com ou sem formatacao)",
            "schema": { "type": "string", "example": "0000001-23.2020.8.26.0100" }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalhes do processo",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "numero_processo": { "type": "string" },
                    "numero_formatado": { "type": "string" },
                    "tribunal": { "type": "string" },
                    "classe_codigo": { "type": "integer" },
                    "classe_nome": { "type": "string" },
                    "grau": { "type": "string" },
                    "data_ajuizamento": { "type": "string" },
                    "orgao_julgador": { "type": "string" },
                    "assuntos": { "type": "string" },
                    "partes": { "type": "array", "items": { "$ref": "#/components/schemas/Parte" } },
                    "advogados": { "type": "array", "items": { "$ref": "#/components/schemas/Advogado" } }
                  }
                },
                "example": {
                  "numero_processo": "00000012320208260100",
                  "numero_formatado": "0000001-23.2020.8.26.0100",
                  "tribunal": "TJ-SP",
                  "classe_codigo": 1234,
                  "classe_nome": "Procedimento Comum Cível",
                  "grau": "G1",
                  "data_ajuizamento": "2020-01-15",
                  "orgao_julgador": "1ª Vara Cível",
                  "assuntos": "Indenização por Dano Moral",
                  "partes": [
                    { "nome": "João Silva", "documento": "12345678901", "polo": "Autor", "tipo": "Física" },
                    { "nome": "Empresa X LTDA", "documento": "12345678000199", "polo": "Réu", "tipo": "Jurídica" }
                  ],
                  "advogados": [
                    { "nome": "Dr. José Advogado", "documento": "98765432100", "oab": "SP123456" }
                  ]
                }
              }
            }
          },
          "400": { "description": "Parametro invalido", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Token ausente ou invalido", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/processos/jobs/{jobId}": {
      "get": {
        "operationId": "getProcessosJobStatus",
        "summary": "Status do job de processos",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status do job",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "ID do job"
                    },
                    "status": {
                      "type": "string",
                      "description": "Status atual do job",
                      "enum": ["pending", "processing", "completed", "failed"]
                    },
                    "progress": {
                      "type": "integer",
                      "description": "Progresso de 0 a 100"
                    },
                    "data": {
                      "type": "object",
                      "description": "Resultado do job quando completo"
                    }
                  },
                  "example": {
                    "id": "abc123",
                    "status": "completed",
                    "progress": 100,
                    "data": {}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parametro invalido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token ausente ou invalido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}