                        "valor_total": 75000.0,
                        "produtos": [
                          "Eucalipto"
                        ],
                        "por_produto": [
                          {
                            "produto": "Eucalipto",
                            "qtd": 5,
                            "volume": 250.0,
                            "valor": 75000.0,
                            "unidade": "m3"
                          }
                        ],
                        "periodo": {
                          "primeiro": "2023-03-10",
                          "ultimo": "2024-08-20"
                        },
                        "operacoes": [
                          {
                            "data_emissao": "2024-08-20",
                            "produto": "Eucalipto",
                            "nome_popular": "Eucalipto",
                            "volume": 50.0,
                            "unidade": "m3",
                            "valor_total": 15000.0
                          }
                        ]
                      }
                    ]
                  },
                  "infracoes": [
                    {
                      "numero_auto": "9876543",
                      "tipo_auto": "Multa",
